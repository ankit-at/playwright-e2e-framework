# Copy this file to .env and fill in real values:  cp .env.example .env
# .env is gitignored and never committed. In CI these are provided as
# GitHub Actions secrets / Jenkins credentials (same variable names).

# rahulshettyacademy account — used by the /client UI + API (newlogin),
# the EventHub app (events), the angular practice form, and the k6 load tests.
RSA_EMAIL=
RSA_PASSWORD=

# ProtoCommerce loginpagePractise account (login.properties / uibasic.spec.js)
PROTO_USER=
PROTO_PASS=

# EventHub booking personas (bookingAuth.spec.js)
YAHOO_EMAIL=
YAHOO_PASSWORD=
GMAIL_EMAIL=
GMAIL_PASSWORD=
