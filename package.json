{
  "name": "playwright",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npx playwright test",
    "test:smoke": "npx playwright test tests/webAPI.spec.ts tests/bookingAuth.spec.ts",
    "perf": "npx playwright test tests/performance.spec.ts --reporter=line",
    "build:k6": "esbuild k6/login-api.ts k6/login-browser.ts --bundle --format=esm --outdir=dist/k6 --external:k6 --external:'k6/*'",
    "load:browser": "artillery run artillery/login-browser.yml",
    "load:k6": "npm run build:k6 && ./tools/k6 run dist/k6/login-api.js",
    "load:k6-browser": "npm run build:k6 && K6_BROWSER_HEADLESS=true K6_BROWSER_EXECUTABLE_PATH=\"$HOME/Library/Caches/ms-playwright/chromium-1223/chrome-mac-arm64/Google Chrome for Testing.app/Contents/MacOS/Google Chrome for Testing\" ./tools/k6 run dist/k6/login-browser.js",
    "report:artillery": "tsx artillery/make-report.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/playwright": "^1.1.6",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/k6": "^2.0.0",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.42.0",
    "allure-playwright": "^3.9.0",
    "artillery": "^2.0.32",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  }
}
